# Dependencies
node_modules/

# Build output
dist/
out/
.next/
.next-*/
*.tsbuildinfo
next-env.d.ts

# Test coverage
coverage/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.claude/
*.swp
*.swo

# Environment
.env
.env.*
!.env.example

# Debug logs
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary session artifacts
.tmp-*

# SQLite runtime data
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Internal (private, not for public repo)
/.apps/
/.contracts/
/.projects/
/.workflows/
# .architecture, .skills, .worklog, .opencode are private git submodules
# (see .gitmodules). Public clones will 404 on submodule init —
# this is expected; public repo functions standalone per the
# conditional in AGENTS.md (the "If .skills/ is present" branch).
# DO NOT re-add them to .gitignore: they must be parent-tracked
# gitlinks for cross-worktree visibility.

# Misc
*.pem

# Internal markdown at root — keep public repo minimal.
# Only README.md, CONTRIBUTING.md, LICENSE (and LICENSE.md) remain visible.
/*.md
!/README.md
!/CONTRIBUTING.md
!/AGENTS.md
!/LICENSE
!/LICENSE.md

# Local recovery script — not part of SP 1.17 scope
scripts/recover-worklog.mjs
